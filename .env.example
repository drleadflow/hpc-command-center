# DLF Command Center - Required Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# MySQL Database (Railway or other provider)
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=

# Alternative: full DATABASE_URL connection string
DATABASE_URL=

# Anthropic / Claude AI
ANTHROPIC_API_KEY=

# UptimeRobot
UPTIMEROBOT_API_KEY=

# Meta / Facebook / Instagram
META_USER_TOKEN=
META_ACCESS_TOKEN=

# Google OAuth & Calendar
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub
GITHUB_TOKEN=
GITHUB_OWNER=drleadflow
GITHUB_REPO=blade-ops

# YouTube
YOUTUBE_API_KEY=

# Apify
APIFY_TOKEN=

# Airtable
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_CONTENT_API_KEY=

# Mux (video)
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=

# Slack
SLACK_BOT_TOKEN=

# ElevenLabs
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=

# Cartesia (TTS)
CARTESIA_API_KEY=

# GoHighLevel (GHL)
GHL_API_KEY=
GHL_LOCATION_ID=

# ManyChat
MANYCHAT_TOKEN=

# Telegram (Vercel webhook notifications)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
VERCEL_WEBHOOK_SECRET=

# App URL (Next.js)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OpenClaw Gateway (Lyra bridge)
OPENCLAW_GATEWAY_URL=
